#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint
echo "📋 Running ESLint..."
npm run lint

# Security scan with bypass option
if [ "$SKIP_SECURITY_SCAN" = "true" ]; then
    echo "⚠️ Security scan bypassed via SKIP_SECURITY_SCAN=true"
else
    echo "🔒 Running free security checks..."

    # Run npm audit (non-blocking)
    echo "📦 Checking dependencies with npm audit..."
    npm audit --audit-level=high || echo "⚠️ Vulnerabilities found - check npm audit output"

    # Note: Full CodeQL analysis runs in GitHub Actions
    echo "ℹ️ Full security analysis available in GitHub Actions workflow"
    echo "✅ Pre-commit security check completed (non-blocking)"
fi
