{
  "dashboard": {
    "id": null,
    "title": "VendFinder Inventory & Sales Dashboard",
    "tags": ["vendfinder", "inventory", "sales"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Total Revenue by Vendor",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "vendfinder_vendor_revenue_dollars",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1000},
                {"color": "red", "value": 5000}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "Products by Vendor & Category",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum by (vendor_name, category) (vendfinder_vendor_products_total)",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"},
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
          "orientation": "horizontal",
          "displayMode": "list",
          "showUnfilled": true
        }
      },
      {
        "id": 3,
        "title": "Orders by Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum by (status) (vendfinder_orders_by_status)",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
          "pieType": "pie",
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "visible", "placement": "bottom"},
          "displayLabels": ["name"]
        }
      },
      {
        "id": 4,
        "title": "Payments by Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "sum by (payment_status) (vendfinder_payments_by_status)",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
          "pieType": "pie",
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "visible", "placement": "bottom"},
          "displayLabels": ["name"]
        }
      },
      {
        "id": 5,
        "title": "Top Selling Products",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "topk(10, vendfinder_vendor_sales_total)",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "continuous-GrYlRd"},
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Vendor Revenue Over Time",
        "type": "timeseries",
        "gridPos": {"h": 9, "w": 24, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "vendfinder_vendor_revenue_dollars",
            "format": "time_series",
            "refId": "A",
            "legendFormat": "{{vendor_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {"mode": "palette-classic"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 1,
              "fillOpacity": 0,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "auto",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {"type": "linear"},
              "axisCenteredZero": false,
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "off"}
            }
          }
        },
        "options": {
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "visible", "placement": "bottom", "calcs": []}
        }
      },
      {
        "id": 7,
        "title": "Vendor Performance Table",
        "type": "table",
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 25},
        "targets": [
          {
            "expr": "vendfinder_vendor_revenue_dollars",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "sum by (vendor_id, vendor_name) (vendfinder_vendor_products_total)",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "sum by (vendor_id, vendor_name) (vendfinder_vendor_sales_total)",
            "format": "table",
            "instant": true,
            "refId": "C"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {
              "reducers": []
            }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "job": true,
                "instance": true,
                "app": true
              },
              "indexByName": {},
              "renameByName": {
                "vendor_name": "Vendor",
                "vendor_id": "Vendor ID",
                "Value #A": "Revenue ($)",
                "Value #B": "Products",
                "Value #C": "Sales"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "cellOptions": {"type": "auto"},
              "inspect": false
            },
            "mappings": []
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Revenue ($)"},
              "properties": [
                {"id": "unit", "value": "currencyUSD"},
                {"id": "custom.cellOptions", "value": {"type": "color-background"}},
                {"id": "color", "value": {"mode": "continuous-GrYlRd"}}
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Product Inventory by Category",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
        "targets": [
          {
            "expr": "sum by (vendor_name, category) (vendfinder_product_inventory)",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "scaleDistribution": {"type": "linear"}
            }
          }
        }
      },
      {
        "id": 9,
        "title": "HTTP Request Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 37},
        "targets": [
          {
            "expr": "rate(vendfinder_http_requests_total[5m])",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Database Query Duration",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 37},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(vendfinder_db_query_duration_seconds_bucket[5m]))",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      }
    ],
